# Marketing site env vars.
# Copy to .env.local for local dev; set in Vercel project settings for previews + production.
#
# Both values live in the repo-root .env already — copy verbatim.

NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Resend transactional email — the early-access welcome email sent by
# POST /api/early-access. relaykit.ai must be a verified sending domain in
# Resend for joel@relaykit.ai to send. Set in .env.local + Vercel.
RESEND_API_KEY=

# PostHog product analytics (US cloud). Token is public-safe but redacted here;
# see PostHog project settings for the live value. Host is not a secret.
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=phc_xxx
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Absolute site origin. Used for blog canonical links, OG/Twitter tags, the
# RSS feed, and the sitemap. Falls back to https://relaykit.ai when unset, but
# Vercel Preview + Production must set this explicitly so preview URLs resolve.
NEXT_PUBLIC_SITE_URL=https://relaykit.ai
